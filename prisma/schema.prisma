// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  patientId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
}

model Patient {
  id          String  @id @default(uuid())
  name        String
  age         Int
  condition   String // "diabetes" | "hypertension" | "asthma" | "heart_disease"
  caregiverId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user           User?
  medications    Medication[]
  symptoms       SymptomLog[]
  vitals         VitalsEntry[]
  reminders      Reminder[]
  alerts         RiskAlert[]
  checkIns       CheckIn[]
  medicationLogs MedicationLog[]
}

model Medication {
  id        String   @id @default(uuid())
  patientId String
  name      String
  dosage    String?
  frequency String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicationLogs MedicationLog[]

  @@index([patientId])
}

model SymptomLog {
  id        String   @id @default(uuid())
  patientId String
  timestamp DateTime
  symptoms  String[]
  severity  Int // 1 | 2 | 3 | 4 | 5
  rawText   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([timestamp])
}

model VitalsEntry {
  id        String   @id @default(uuid())
  patientId String
  timestamp DateTime
  type      String // "blood_pressure" | "blood_sugar" | "weight" | "heart_rate"
  value     Float
  unit      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([timestamp])
}

model Reminder {
  id          String   @id @default(uuid())
  patientId   String
  type        String // "medication" | "appointment"
  label       String
  scheduledAt DateTime
  status      String // "pending" | "done" | "snoozed" | "missed"
  missedCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([scheduledAt])
}

model RiskAlert {
  id          String   @id @default(uuid())
  patientId   String
  triggeredAt DateTime
  rule        String
  severity    String // "warning" | "critical"
  insight     String
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([triggeredAt])
}

model MedicationLog {
  id           String   @id @default(uuid())
  patientId    String
  medicationId String
  takenAt      DateTime
  status       String // "taken" | "missed" | "skipped"
  notes        String?
  missedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([medicationId])
  @@index([takenAt])
}

model CheckIn {
  id        String   @id @default(uuid())
  patientId String
  date      DateTime
  notes     String?
  mood      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([date])
}
